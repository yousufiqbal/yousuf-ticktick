# Drizzle
# Replace with your DB credentials!
DATABASE_URL="libsql://db-name-user.turso.io"
# A local DB can also be used in dev as well
# DATABASE_URL="file:local.db"
DATABASE_AUTH_TOKEN=""

# Auth
SESSION_SECRET=""
# bcrypt hash of your admin password. In THIS file (loaded via Vite's
# dotenv-expand), escape every "$" as "\$" or the hash gets mangled.
# Vercel's dashboard env vars are not affected — paste the hash unescaped there.
ADMIN_PASSWORD_HASH=""
